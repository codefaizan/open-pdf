{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "app",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "env": {
                "OPEN_PDF_WORKER_EXECUTABLE": "${workspaceFolder}/worker/dist/open_pdf_worker/open_pdf_worker"
            }
        },
        {
            "name": "app (profile mode)",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "env": {
                "OPEN_PDF_WORKER_EXECUTABLE": "${workspaceFolder}/worker/dist/open_pdf_worker/open_pdf_worker"
            }
        },
        {
            "name": "app (release mode)",
            "cwd": "app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "env": {
                "OPEN_PDF_WORKER_EXECUTABLE": "${workspaceFolder}/worker/dist/open_pdf_worker/open_pdf_worker"
            }
        }
    ]
}
